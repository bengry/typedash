{
  "name": "typedash",
  "version": "3.3.3",
  "description": "modern, type-safe collection of utility functions",
  "keywords": [
    "lodash",
    "stdlib",
    "type-safe",
    "typescript",
    "util",
    "utilities",
    "utility"
  ],
  "license": "MIT",
  "author": "Ben Grynhaus <me@bengr.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bengry/typedash"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    }
  },
  "scripts": {
    "build": "vp pack",
    "check": "concurrently \"vp check\" \"ls-lint\" \"pnpm dedupe --check\"",
    "check:fix": "vp check --fix && ls-lint",
    "commit": "czg",
    "deps:dedupe": "pnpm dedupe --check",
    "deps:dedupe:fix": "pnpm dedupe && pnpm install",
    "dev": "concurrently \"vp pack --watch\" \"vp test watch\"",
    "filenames": "ls-lint",
    "fmt": "vp fmt --check",
    "fmt:fix": "vp fmt --write",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "prepare": "lefthook install",
    "release": "vp pack && release-it",
    "test": "vp test run --passWithNoTests",
    "test:ci": "vp test run --coverage",
    "test:coverage": "vp test run --coverage",
    "test:ui": "vp test watch --ui",
    "test:watch": "vp test watch",
    "type-check": "vp check --no-fmt --no-lint",
    "update:interactive": "taze --interactive",
    "update:minor": "taze minor",
    "util:function-count": "exa -1 | grep -v '^_' | wc -l"
  },
  "dependencies": {
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@ls-lint/ls-lint": "^2.3.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.16",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "concurrently": "^10.0.0",
    "czg": "^1.13.1",
    "lefthook": "^2.1.9",
    "react": "^19.2.6",
    "release-it": "^20.0.1",
    "taze": "^19.14.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.23"
  },
  "peerDependencies": {
    "react": ">=18 < 20"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
