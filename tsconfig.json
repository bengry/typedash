{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "allowJs": true,
    "noUncheckedIndexedAccess": true,
    "types": ["node"],
    "rootDirs": ["./src"]
  },
  "include": ["./src", "vite.config.ts"]
}
